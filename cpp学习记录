	{
		cout << "恭喜您考上！" << endl;
	}
	else
	{
		cout << "继续加油！" << endl;
	}

2.多条件的if
语法：
if (条件1){条件1满足执行的语句} else if (条件2){条件2满足执行的语句}...else{都不满足执行的语句}
	int score = 0;
	cout << "请输入您的分数： " << endl;
	cin >> score;

	cout << "您输入的分数为：" << score << endl;
	if (score >= 600)
	{
		cout << "恭喜您考上一本！" << endl;
	}
		else if (score >= 500)
	{
		cout << "恭喜您考上二本" << endl;
	}
		else if (score >= 100)
	{
		cout << "继续加油！" << endl;
	}
		else
	{
		cout << "你废了！！！" << endl;
	}
