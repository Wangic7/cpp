3.递增递减
int a1 = 10;
++a1;
cout << a1 << endl;

int b1 = 10;
b1++;
cout << b1 << endl;

int a2 = 10;
int b2 = ++a2 * 10;  //前置先对变量加加 再进行表达式
cout << a2 << endl; //11
cout << b2 << endl;//110

int a3 = 10;
int b3 = a3++ * 10;  //后置先运算表达式 再进行加加  减减同理
cout << a3 << endl;  //11
cout << b3 << endl; //100

int a4 = 10;
int b4 = --a4 * 10;
cout << "b4= " << b4 << endl;// 9 90

int a5 = 10;
int b5 = a5-- * 10;
cout << "b5= " << b5 << endl;// 9 100

